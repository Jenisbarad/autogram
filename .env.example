# =============================================
# INSTA-AUTOGRAM — ENVIRONMENT VARIABLES
# =============================================

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:12341234@127.0.0.1:5432/insta_autogram
DB_HOST=localhost
DB_PORT=5432
DB_NAME=insta_autogram
DB_USER=postgres
DB_PASSWORD=12341234

# ─── Redis ───────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Server ──────────────────────────────────────────────
BACKEND_PORT=4000
BACKEND_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# ─── AI Provider (ALL FREE) ──────────────────────────────
# Pick ONE of the options below:

# OPTION 1 — GROQ (recommended, fastest, 30 req/min free)
#   Get free key: https://console.groq.com
AI_PROVIDER=groq
GROQ_API_KEY=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  # <-- paste your key here

# OPTION 2 — Google Gemini Flash (free via AI Studio)
#   Get free key: https://aistudio.google.com/apikey
# AI_PROVIDER=gemini
# GEMINI_API_KEY=AIza_xxxxxxxxxxxxxxxxxxxxxxxxxxxx  # <-- paste your key here

# OPTION 3 — Ollama (100% local, no internet, no limits)
#   Install ollama, then: ollama pull llama3
# AI_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# OPTION 4 — Smart Templates (no API key at all)
# AI_PROVIDER=template

# ─── Content Sources (all free) ──────────────────────────
# Pexels — 200 req/hour free: https://www.pexels.com/api/
PEXELS_API_KEY=IJPFGJcEuYu1qvCrEc1n886Zta39TeCtDPWJe7U7NPHhf3B3vJftD1bT        # <-- paste your key here
# Reddit → no key needed (public JSON API)
# YouTube → no key needed (Playwright scraping)

# ─── Storage ─────────────────────────────────────────────
MEDIA_STORAGE_PATH=./media
MAX_FILE_SIZE_MB=500

# ─── Quality ─────────────────────────────────────────────
MIN_RESOLUTION=720
MIN_DURATION_SECONDS=3
MAX_DURATION_SECONDS=90

# ─── Viral Score ─────────────────────────────────────────
VIRAL_SCORE_THRESHOLD=0.25
AUTO_POST_ENABLED=false
AUTO_POST_VIRAL_THRESHOLD=0.70

# ─── Queue ───────────────────────────────────────────────
QUEUE_CONCURRENCY=2
JOB_ATTEMPTS=3
JOB_BACKOFF_MS=5000
