{
  "name": "insta-autogram",
  "version": "1.0.0",
  "description": "Instagram Auto-Upload System",
  "main": "backend/src/index.js",
  "scripts": {
    "start": "cd backend && npm start",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install"
  },
  "dependencies": {
    "@bull-board/api": "^5.5.0",
    "@bull-board/express": "^5.5.0",
    "@google/generative-ai": "^0.3.1",
    "axios": "^1.6.7",
    "bcryptjs": "^3.0.3",
    "bullmq": "^3.15.8",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-async-errors": "^3.1.1",
    "express-basic-auth": "^1.2.1",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.0",
    "groq-sdk": "^0.37.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.28.4",
    "pg": "^8.11.3",
    "playwright": "^1.42.1",
    "sharp": "^0.33.2",
    "slug": "^9.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
