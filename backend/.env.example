# ────────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT VARIABLES TEMPLATE - Instagram Auto-Upload System
# ────────────────────────────────────────────────────────────────────────────────

# ────────────────────────────────────────────────────────────────────────────────
# REQUIRED - Database & Core Settings
# ────────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/insta_autogram
DB_HOST=localhost
DB_PORT=5432
DB_NAME=insta_autogram
DB_USER=postgres
DB_PASSWORD=password

# ────────────────────────────────────────────────────────────────────────────────
# REQUIRED - Backend Settings
# ────────────────────────────────────────────────────────────────────────────────
BACKEND_PORT=4000
NODE_ENV=development
MEDIA_STORAGE_PATH=./media

# ────────────────────────────────────────────────────────────────────────────────
# REQUIRED - Public URL (IMPORTANT!)
# ────────────────────────────────────────────────────────────────────────────────
# This is REQUIRED for bots and iOS shortcuts to work
# For local development, use ngrok or tunnelmole
# For production, use your actual domain
PUBLIC_BACKEND_URL=https://your-domain.com

# ────────────────────────────────────────────────────────────────────────────────
# OPTIONAL - Telegram Bot
# ────────────────────────────────────────────────────────────────────────────────
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ────────────────────────────────────────────────────────────────────────────────
# OPTIONAL - WhatsApp Business API
# ────────────────────────────────────────────────────────────────────────────────
# Get these from Meta for Developers dashboard
WHATSAPP_VERIFY_TOKEN=your_secret_verify_token_here
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_from_meta
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id

# ────────────────────────────────────────────────────────────────────────────────
# OPTIONAL - AI Caption Generation
# ────────────────────────────────────────────────────────────────────────────────
# Choose: groq, gemini, ollama, template
AI_PROVIDER=groq

# Groq (FREE) - Get key from https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Gemini Flash 2.0 (FREE) - Get key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama (LOCAL) - No API key needed
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ────────────────────────────────────────────────────────────────────────────────
# OPTIONAL - Content Discovery APIs
# ────────────────────────────────────────────────────────────────────────────────
# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# Pexels Videos API
PEXELS_API_KEY=your_pexels_api_key_here

# ────────────────────────────────────────────────────────────────────────────────
# OPTIONAL - Rate Limiting (default values shown)
# ────────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_YOUTUBE_DAILY=100
RATE_LIMIT_REDDIT_MINUTE=60
RATE_LIMIT_INSTAGRAM_HOURLY=200
RATE_LIMIT_PEXELS_HOURLY=200

# ────────────────────────────────────────────────────────────────────────────────
# OPTIONAL - Queue Settings
# ────────────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
QUEUE_CONCURRENCY=2
JOB_ATTEMPTS=3
JOB_BACKOFF_MS=5000

# ────────────────────────────────────────────────────────────────────────────────
# OPTIONAL - Transformation Settings
# ────────────────────────────────────────────────────────────────────────────────
# Enable/disable specific transformations
TRANSFORM_MIRROR=true
TRANSFORM_SPEED_MIN=1.0
TRANSFORM_SPEED_MAX=1.15
TRANSFORM_ZOOM_MAX=0.05

# ────────────────────────────────────────────────────────────────────────────────
# OPTIONAL - Viral Score Settings
# ────────────────────────────────────────────────────────────────────────────────
VIRAL_SCORE_THRESHOLD=0.05
MAX_FILE_SIZE_MB=500

# ─── Security Settings ─────────────────────────────────────
# Block submissions from private Instagram accounts (recommended: true)
BLOCK_PRIVATE_ACCOUNTS=true
